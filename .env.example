# Copy to .env and fill in your values, then: source .env

# Anthropic API key – https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Zapier MCP endpoint – copy from actions.zapier.com/mcp
ZAPIER_MCP_URL=https://mcp.zapier.com/api/mcp/mcp?...

# --- gmail_inbox_agent.py only ---
# Optional: second Zapier MCP endpoint with LinkedIn Search or Web Search actions
# Add "LinkedIn: Find Profile" or "Web Search" in your Zapier MCP actions,
# then paste that MCP URL here for sender enrichment
ENRICHMENT_MCP_URL=https://mcp.zapier.com/api/mcp/mcp?...

# --- advisor_intake_agent.py only ---
# Email address that receives the intake summary
ADVISOR_EMAIL=you@example.com
